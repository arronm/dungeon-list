{
  "name": "@dungeon-list/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "build:extension-zip": "npm run build && node ../../scripts/build-extension-zip.mjs",
    "typecheck": "npm run build -w @dungeon-list/shared && tsc -p tsconfig.json --noEmit",
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "test": "npm run build -w @dungeon-list/shared && vitest run"
  },
  "dependencies": {
    "@dungeon-list/shared": "0.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
